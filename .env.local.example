# ═══════════════════════════════════════════════════════════════
# GLOBAL COCO EXPORTS — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# ═══════════════════════════════════════════════════════════════

# ─── Google Analytics 4 ───────────────────────────
# Create a GA4 property at https://analytics.google.com/
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA4_ID=

# ─── Microsoft Clarity ─────────────────────────────
# Create a Clarity project at https://clarity.microsoft.com/
# Format: xxxxxxxx (8-character hex ID)
NEXT_PUBLIC_CLARITY_ID=

# ─── Google Search Console ─────────────────────────
# Verify your domain via DNS TXT record or HTML file.
# Add the verification meta tag or DNS record at https://search.google.com/search-console/

# ─── Resend (Transactional Email) ──────────────────
# Create an API key at https://resend.com/
RESEND_API_KEY=

# ─── Resend — Verified Sender Domain ───────────────
# Once you verify a domain at https://resend.com/domains, set your
# sender address here. Falls back to onboarding@resend.dev (Resend sandbox).
# Example: noreply@yourdomain.com
RESEND_FROM_DOMAIN=

# ─── Supabase ──────────────────────────────────────
# Create a project at https://supabase.com/
# Find these values in: Project Settings → API
#
# SUPABASE_URL         — your project URL (e.g. https://xxxx.supabase.co)
# SUPABASE_SERVICE_ROLE_KEY — secret service role key (server-side ONLY — never expose to browser)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Site URL ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://www.globalcocoexports.com
